{% extends 'base.html.twig' %}

{% block title %}Confmateriel index{% endblock %}

{% block body %}
    <h1>Confmateriel index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Datereservation</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for confmateriel in confmateriels %}
            <tr>
                <td>{{ confmateriel.id }}</td>
                <td>{{ confmateriel.datereservation ? confmateriel.datereservation|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_confmateriel_show', {'id': confmateriel.id}) }}">show</a>
                    <a href="{{ path('app_confmateriel_edit', {'id': confmateriel.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_confmateriel_new') }}">Create new</a>
{% endblock %}
