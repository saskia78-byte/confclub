
{% block main %}
<div class="min-h-screen bg-slate-950 text-white px-6 py-10">

    {# Header #}
    <div class="mb-10 border-b border-slate-700 pb-6">
        <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-1">confClub</p>
        <h1 class="text-4xl font-bold text-white">{{ button_label|default('Nouveau conférencier') }}</h1>
    </div>

    {# Formulaire #}
    <div class="max-w-lg">
        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

            {# Nom #}
            <div>
                {{ form_label(form.nom, 'Nom', {'label_attr': {'class': 'block text-xs font-semibold tracking-widest text-slate-400 uppercase mb-2'}}) }}
                {{ form_widget(form.nom, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-lg px-4 py-3 focus:outline-none focus:border-indigo-500 transition-colors'}}) }}
                {{ form_errors(form.nom) }}
            </div>

            {# Prénom #}
            <div>
                {{ form_label(form.prenom, 'Prénom', {'label_attr': {'class': 'block text-xs font-semibold tracking-widest text-slate-400 uppercase mb-2'}}) }}
                {{ form_widget(form.prenom, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-lg px-4 py-3 focus:outline-none focus:border-indigo-500 transition-colors'}}) }}
                {{ form_errors(form.prenom) }}
            </div>

            {# Conférences #}
            <div>
                {{ form_label(form.confs, 'Conférences', {'label_attr': {'class': 'block text-xs font-semibold tracking-widest text-slate-400 uppercase mb-2'}}) }}
                {{ form_widget(form.confs, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-lg px-4 py-3 focus:outline-none focus:border-indigo-500 transition-colors'}}) }}
                <p class="mt-1 text-xs text-slate-500">Maintenez Ctrl (ou Cmd sur Mac) pour sélectionner plusieurs conférences.</p>
                {{ form_errors(form.confs) }}
            </div>

            {# Bouton #}
            <div class="pt-2">
                <button type="submit"
                        class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors duration-200">
                    {{ button_label|default('Enregistrer') }}
                </button>
            </div>

        {{ form_end(form) }}

        {# Retour #}
        <div class="mt-4 text-center">
            <a href="{{ path('app_conferencier_index') }}"
            class="text-xs text-slate-500 hover:text-slate-300 transition-colors">
                ← Retour à la liste
            </a>
        </div>
    </div>

</div>
{% endblock %}
