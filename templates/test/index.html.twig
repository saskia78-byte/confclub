{% extends 'base.html.twig' %}

{% block title %}ConfClub — Conférences{% endblock %}

{% block body %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --bg:        #0a0a0f;
        --surface:   #111118;
        --border:    #1e1e2e;
        --accent:    #7c6aff;
        --accent2:   #ff6a9b;
        --text:      #e8e8f0;
        --muted:     #5a5a78;
        --emerald:   #34d399;
        --red:       #f87171;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
    }

    /* ── PAGE WRAPPER ── */
    .cc-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
    }

    /* ── HEADER ── */
    .cc-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 2.5rem;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .cc-logo-block {}

    .cc-eyebrow {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .cc-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2.2rem, 5vw, 3.8rem);
        font-weight: 800;
        line-height: 1;
        background: linear-gradient(135deg, #fff 30%, var(--accent) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .cc-subtitle {
        margin-top: 0.5rem;
        font-size: 0.9rem;
        color: var(--muted);
        font-weight: 300;
    }

    .cc-contact-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 1.2rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--muted);
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }
    .cc-contact-link:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: rgba(124,106,255,0.07);
    }
    .cc-contact-link svg { width: 14px; height: 14px; }

    /* ── DIVIDER ── */
    .cc-divider {
        height: 1px;
        background: linear-gradient(90deg, var(--accent) 0%, transparent 60%);
        margin-bottom: 1.5rem;
        opacity: 0.4;
    }

    /* ── TABLE CARD ── */
    .cc-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 0 60px rgba(124,106,255,0.06);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    /* ── THEAD ── */
    thead tr {
        border-bottom: 1px solid var(--border);
    }
    thead th {
        padding: 0.85rem 1.2rem;
        text-align: left;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
    }

    /* ── TBODY ── */
    tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.15s;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(255,255,255,0.025); }

    td {
        padding: 1rem 1.2rem;
        vertical-align: middle;
    }

    /* ── TITRE ── */
    .td-titre {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        color: #fff;
    }

    /* ── DATE ── */
    .td-date {
        font-size: 0.82rem;
        color: var(--muted);
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }

    /* ── BADGES GÉNÉRIQUES ── */
    .badge {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 600;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        letter-spacing: 0.04em;
    }
    .badge-actif    { background: rgba(52,211,153,0.12); color: var(--emerald); border: 1px solid rgba(52,211,153,0.25); }
    .badge-annule   { background: rgba(248,113,113,0.1);  color: var(--red);     border: 1px solid rgba(248,113,113,0.2); }
    .badge-default  { background: rgba(255,255,255,0.05); color: var(--muted);   border: 1px solid var(--border); }
    .badge-conf     { background: rgba(124,106,255,0.1);  color: #a89dff;        border: 1px solid rgba(124,106,255,0.2); margin: 2px; }
    .badge-theme    { background: rgba(255,106,155,0.08); color: #ff9ec0;        border: 1px solid rgba(255,106,155,0.18); }

    .td-chips { display: flex; flex-wrap: wrap; gap: 4px; }

    /* ── EMPTY STATE ── */
    .empty-row td {
        text-align: center;
        padding: 4rem 1rem;
        color: var(--muted);
        font-size: 0.85rem;
        font-style: italic;
    }

    /* ── HERO IMAGE ── */
    .cc-image {
        margin-top: 2.5rem;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
        position: relative;
    }
    .cc-image::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(10,10,15,0.7) 0%, transparent 50%);
        pointer-events: none;
    }
    .cc-image img {
        width: 100%;
        height: 260px;
        object-fit: cover;
        display: block;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
        .hide-mobile { display: none; }
    }
</style>

<div class="cc-wrapper">

    {# ── EN-TÊTE ── #}
    <header class="cc-header">
        <div class="cc-logo-block">
            <h1 class="cc-title">ConfClub</h1>
            <p class="cc-subtitle">Les 3 prochaines conférences</p>
        </div>
        <a href="{{ path('app_contact') }}" class="cc-contact-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Contact
        </a>
    </header>

    <div class="cc-divider"></div>

    {# ── TABLEAU ── #}
    <div class="cc-card">
        <table>
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th class="hide-mobile">Conférenciers</th>
                    <th class="hide-mobile">Thème</th>
                </tr>
            </thead>
            <tbody>
                {% for conf in confs %}
                <tr>
                    {# Titre #}
                    <td class="td-titre">{{ conf.titre }}</td>

                    {# Date #}
                    <td class="td-date">
                        {{ conf.dateConf ? conf.dateConf|date('d/m/Y') : '—' }}
                    </td>

                    {# Statut #}
                    <td>
                        {% if conf.statut == 'actif' %}
                            <span class="badge badge-actif">Actif</span>
                        {% elseif conf.statut == 'annulé' %}
                            <span class="badge badge-annule">Annulé</span>
                        {% else %}
                            <span class="badge badge-default">{{ conf.statut ?? '—' }}</span>
                        {% endif %}
                    </td>

                    {# Conférenciers #}
                    <td class="hide-mobile">
                        <div class="td-chips">
                            {% for conferencier in conf.conferencier %}
                                <span class="badge badge-conf">{{ conferencier.prenom }} {{ conferencier.nom }}</span>
                            {% else %}
                                <span style="font-size:0.78rem;color:var(--muted);font-style:italic">Aucun</span>
                            {% endfor %}
                        </div>
                    </td>

                    {# Thème #}
                    <td class="hide-mobile">
                        {% if conf.theme %}
                            <span class="badge badge-theme">{{ conf.theme.libelle }}</span>
                        {% else %}
                            <span style="font-size:0.78rem;color:var(--muted);font-style:italic">Aucun</span>
                        {% endif %}
                    </td>
                </tr>
                {% else %}
                <tr class="empty-row">
                    <td colspan="5">Aucune conférence trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# ── IMAGE ── #}
    <div class="cc-image">
        <img src="{{ asset('image/pexels-asia.jpg') }}" alt="Illustration conférence">
    </div>

</div>
{% endblock %}
