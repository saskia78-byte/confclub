{% extends 'base.html.twig' %}

{% block title 'Conférences' %}

{% block main %}
    <h1>Creer une conférence: </h1>

    {{ form_start(form) }}
    <div class="d-flex">
        {{ form_row(form.titre) }}
        {{ form_row(form.description) }}
        {{ form_row(form.statut) }}
    </div>
    {{ form_end(form) }}

{% endblock %}