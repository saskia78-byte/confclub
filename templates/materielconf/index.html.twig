{% extends 'base.html.twig' %}

{% block title %}Matériel des conférences{% endblock %}

{% block main %}
<div class="min-h-screen bg-slate-950 text-white px-6 py-10">

    {# Header #}
    <div class="mb-10 flex items-end justify-between border-b border-slate-700 pb-6">
        <div>
            <p class="text-xs font-semibold tracking-widest text-indigo-400 uppercase mb-1">confClub</p>
            <h1 class="text-4xl font-bold text-white">Matériel des conférences</h1>
        </div>
        <a href="{{ path('app_materielconf_new') }}"
        class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors duration-200">
            + Nouvelle réservation
        </a>
    </div>

    {# Table #}
    <div class="overflow-x-auto rounded-xl border border-slate-800">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-slate-900 text-slate-400 text-xs uppercase tracking-wider">
                    <th class="px-5 py-4 text-left">#</th>
                    <th class="px-5 py-4 text-left">Matériel</th>
                    <th class="px-5 py-4 text-left">Conférence</th>
                    <th class="px-5 py-4 text-left">Date de réservation</th>
                    <th class="px-5 py-4 text-left">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
            {% for materielconf in materielconfs %}
                <tr class="bg-slate-900 hover:bg-slate-800 transition-colors duration-150">

                    {# ID #}
                    <td class="px-5 py-4 text-slate-500 font-mono text-xs">{{ materielconf.id }}</td>

                    {# Matériel #}
                    <td class="px-5 py-4 font-semibold text-white">
                        {% if materielconf.materiel %}
                            <span class="inline-block bg-indigo-500/10 text-indigo-300 text-xs px-2 py-0.5 rounded-full">
                                {{ materielconf.materiel.libelle }}
                            </span>
                        {% else %}
                            <span class="text-slate-600 text-xs italic">Aucun</span>
                        {% endif %}
                    </td>

                    {# Conférence #}
                    <td class="px-5 py-4 text-slate-300">
                        {% if materielconf.conf %}
                            {{ materielconf.conf.titre }}
                        {% else %}
                            <span class="text-slate-600 text-xs italic">Aucune</span>
                        {% endif %}
                    </td>

                    {# Date de réservation #}
                    <td class="px-5 py-4 text-slate-300 whitespace-nowrap">
                        {{ materielconf.dateresa ? materielconf.dateresa|date('d/m/Y H:i') : '—' }}
                    </td>

                    {# Actions #}
                    <td class="px-5 py-4">
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_materielconf_show', {'id': materielconf.id}) }}"
                            class="text-xs font-medium text-slate-300 hover:text-white bg-slate-700 hover:bg-slate-600 px-3 py-1.5 rounded-md transition-colors">
                                Voir
                            </a>
                            <a href="{{ path('app_materielconf_edit', {'id': materielconf.id}) }}"
                            class="text-xs font-medium text-indigo-300 hover:text-white bg-indigo-700/40 hover:bg-indigo-600 px-3 py-1.5 rounded-md transition-colors">
                                Éditer
                            </a>
                            <a href="{{ path('app_materielconf_delete', {'id': materielconf.id}) }}"
                            class="text-xs font-medium text-indigo-300 hover:text-white bg-indigo-700/40 hover:bg-indigo-600 px-3 py-1.5 rounded-md transition-colors">
                                Supprimer
                            </a>
                        </div>
                    </td>

                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="px-5 py-16 text-center text-slate-600 italic">
                        Aucune réservation trouvée.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
