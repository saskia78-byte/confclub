{% extends 'base.html.twig' %}

{% block title %}Materiel{% endblock %}

{% block main %}
<div class="min-h-screen bg-slate-950 text-white px-6 py-10">
    <h1 class="text-5xl font-bold tracking-tight text-white"> Materiels</h1>
    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ materiel.id }}</td>
            </tr>
            <tr>
                <th>Libelle</th>
                <td>{{ materiel.libelle }}</td>
            </tr>
        </tbody>
    </table>
    <div class="flex items-center gap-3">
        <a href="{{ path('app_materiel_index') }}"
        class="text-xs font-medium text-white bg-slate-600 hover:bg-slate-500 px-3 py-1.5 rounded-md transition-colors">
            ← Retour à la liste
        </a>
        <a href="{{ path('app_materiel_edit', {'id': materiel.id}) }}"
        class="text-xs font-medium text-white bg-indigo-600 hover:bg-indigo-500 px-3 py-1.5 rounded-md transition-colors">
            Éditer
        </a>
        <a href="{{ path('app_materiel_delete', {'id': materiel.id}) }}"
        class="text-xs font-medium text-white bg-red-600 hover:bg-red-500 px-3 py-1.5 rounded-md transition-colors">
            Supprimer
        </a>
    </div>
</div>
{% endblock %}
